{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "emitDeclarationOnly": true,
    "outDir": "./node_modules/.cache/tsc-node",
  },
  "include": ["vite.config.ts", "capacitor.config.ts"],
}
